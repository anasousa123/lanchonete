<!DOCTYPE html>
<html>
<body>

<h2>Resumo</h2>
<div id="dados"></div>

<script type="module">
import { db, collection, getDocs } from "./firebase.js";

async function carregar(){
  const snap = await getDocs(collection(db,"pedidos"));

  let total=0;

  snap.forEach(d=>{
    let p=d.data();
    p.itens.forEach(i=> total+=i.preco);
  });

  document.getElementById("dados").innerText =
    "Total vendido: R$ "+total;
}

carregar();
</script>

</body>
</html>